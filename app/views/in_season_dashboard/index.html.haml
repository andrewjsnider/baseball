-# app/views/in_season_dashboard/index.html.haml

%div{ class: "max-w-6xl mx-auto px-6 py-10 text-stone-900" }

  %div{ class: "flex items-start justify-between gap-4 mb-8" }
    %div
      %h1{ class: "text-3xl font-semibold" } In-Season Dashboard
      %p{ class: "text-sm text-stone-600 mt-1" } This week at a glance.

    %div{ class: "flex flex-wrap gap-2 items-center justify-end" }
      = link_to "New Game", new_game_path, class: "border border-stone-900 px-4 py-2 hover:bg-stone-900 hover:text-white whitespace-nowrap"

  %div{ class: "grid grid-cols-1 lg:grid-cols-3 gap-6" }
    = render partial: 'next_game'
    = render partial: 'quick_snapshot'
  %div{ class: "grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6" }
    = render partial: 'upcoming_games'
    = render partial: 'recent_games'
