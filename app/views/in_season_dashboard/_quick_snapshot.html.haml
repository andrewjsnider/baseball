- presenter = @presenter

%div{ class: "border border-stone-300 p-6 bg-white" }
  %h2{ class: "text-lg font-semibold mb-4" } Quick Snapshot

  - next_up_rows = presenter.next_up_rows

  %div{ class: "grid grid-cols-2 gap-4 text-sm" }
    %div
      %div{ class: "text-stone-600" } Available Pitchers
      %div{ class: "text-2xl font-semibold" }= presenter.eligible_pitchers.size

    %div
      %div{ class: "text-stone-600" } Resting Pitchers
      %div{ class: "text-2xl font-semibold" }= presenter.resting_pitchers.size

    %div
      %div{ class: "text-stone-600" } Probable Starter
      %div{ class: "text-base font-semibold" }= presenter.probable_starter_name.presence || "Not set"

    %div
      %div{ class: "text-stone-600" } Next Game
      %div{ class: "text-base font-semibold" }
        - if presenter.next_game.present?
          = presenter.next_game.date.strftime('%m-%d-%Y')
        - else
          None scheduled

  - if next_up_rows.any?
    %div{ class: "mt-4 text-sm" }
      %div{ class: "text-stone-600 mb-1" } Resting pitchers
      %div{ class: "space-y-1" }
        - next_up_rows.each do |row|
          %div
            %span{ class: "font-semibold" }= row.player.name
            %span{ class: "text-stone-600" }
              - if row.eligible_on.present?
                = " eligible again on #{row.eligible_on.strftime('%m-%d-%Y')}"
              - else
                = " eligible date unknown"
