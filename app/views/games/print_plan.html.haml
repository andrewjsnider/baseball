- show = @presenter
- game = show.game
- summary = show.pitching_availability_summary
- eligible_pitchers = show.eligible_pitchers_for_game
- plan_rows = show.pitch_plan_rows
- lineup = game.lineup
- lineup_slots = lineup&.lineup_slots&.includes(:player)&.to_a || []

%div{ class: "no-print flex justify-end mb-3" }
  %button{ class: "border border-stone-900 px-3 py-1 text-sm hover:bg-stone-900 hover:text-white",
           onclick: "window.print()" } Print

%div{ class: "text-xs text-stone-900" }

  %div{ class: "flex items-start justify-between gap-4 mb-2" }
    %div
      %div{ class: "text-lg font-semibold leading-tight" }
        Game Plan
        - if show.opp_name.present?
          %span{ class: "text-stone-600 font-normal" }= " vs #{show.opp_name}"
      %div{ class: "text-stone-600" }= l(show.game_date)

    %div{ class: "text-right" }
      %div{ class: "font-semibold" } Starting pitcher
      %div= show.starting_pitcher_name || "Not assigned"

  %div{ class: "grid grid-cols-12 gap-1" }

    %div{ class: "col-span-6 border border-stone-300 p-2" }
      %div{ class: "font-semibold mb-1" } Pitch plan

      %div{ class: "border border-stone-200" }
        %div{ class: "grid grid-cols-12 px-2 py-1 border-b border-stone-200 bg-stone-50 font-semibold" }
          %div{ class: "col-span-4" } Role
          %div{ class: "col-span-6" } Pitcher
          %div{ class: "col-span-2 text-right" } Target

        - plan_rows.each do |row|
          - name = row.player_name.presence || "Not assigned"
          - pitches = row.target_pitches.to_i > 0 ? "#{row.target_pitches}p" : "-"
          - eligible = row.player_id.present? && show.pitcher_eligible_today?(row.player_id)
          - status_class = eligible ? "text-lime-600" : (row.player_id.present? ? "text-red-700" : "text-stone-600")

          %div{ class: "grid grid-cols-12 px-2 py-2 border-b border-stone-200" }
            %div{ class: "col-span-4 font-semibold" }= row.label
            %div{ class: "col-span-6 font-semibold" }= name
            %div{ class: "col-span-2 text-right text-stone-700" }= pitches

        %div.font-semibold.text-sm.py-5.text-center Average 6-Inning Game: 90 - 130 pitches

    %div{ class: "col-span-6 border border-stone-300 p-2" }
      %div{ class: "font-semibold mb-1" } Lineup (batting order)
      - if lineup_slots.any?

        :ruby
          ordered = lineup_slots
          pos_by_player_id = {}
          ordered.each { |s| pos_by_player_id[s.player_id] = s.field_position }

        %div{ class: "border border-stone-200" }
          %div{ class: "grid grid-cols-12 px-2 py-1 border-b border-stone-200 bg-stone-50 font-semibold" }
            %div{ class: "col-span-1" } #
            %div{ class: "col-span-7" } Batter
            %div{ class: "col-span-4 text-right" } Defense

          - ordered.each_with_index do |slot, idx|
            - name = slot.player&.name || "-"
            - pos = slot.field_position.presence || "extra_hitter"
            %div{ class: "grid grid-cols-12 px-2 py-1 border-b border-stone-200" }
              %div{ class: "col-span-1 text-stone-600" }= idx + 1
              %div{ class: "col-span-7 font-semibold" }= name
              %div{ class: "col-span-4 text-right text-stone-700" }= pos.to_s.humanize

        - if show.missing_positions.any?
          %div{ class: "mt-2 text-red-700 font-semibold" }= "Missing: #{show.missing_positions_label}"

      - else
        %div{ class: "text-stone-600" } No lineup set

  %div{ class: "border border-stone-300 p-2 mt-2" }
    %div{ class: "grid grid-cols-12 gap-2" }
      %div{ class: "col-span-6" }
        %div{ class: "font-semibold mb-1" } Pitching availability
        %div{ class: "text-stone-700" }= "#{summary.eligible_count} eligible, #{summary.resting_count} resting"

        %div{ class: "mt-1" }
          %span{ class: "text-stone-600" } Available:
          - if eligible_pitchers.any?
            %span= eligible_pitchers.map(&:name).join(", ")
          - else
            %span None

      %div{ class: "col-span-6" }
        - if summary.next_up_rows.any?
          %div{ class: "font-semibold mb-1" } Resting pitchers (eligible again)
          %div{ class: "space-y-0.5" }
            - summary.next_up_rows.each do |r|
              %div{ class: "text-red-700" }= "#{r.player_name}: #{r.eligible_on.strftime("%m-%d-%Y")}"
        - else
          %div{ class: "font-semibold mb-1" } Resting pitchers
          %div{ class: "text-stone-600" } None

  %div{ class: "mt-10 border-t border-stone-300 pt-6 text-stone-900" }
    %h3{ class: "font-semibold text-base" } Pitching Rules (Majors)

    %div{ class: "mt-3 text-sm" }
      %div{ class: "font-semibold" } Daily max
      %div{ class: "mt-1" } 85 pitches per day (pitches are cumulative across all games that day, including doubleheaders).

    %div{ class: "mt-4 text-sm" }
      %div{ class: "font-semibold" } Required calendar days of rest (based on pitches thrown in a day)
      %ul{ class: "mt-1 list-disc pl-5 space-y-1" }
        %li 1–20 pitches: 0 days rest
        %li 21–35 pitches: 1 day rest
        %li 36–50 pitches: 2 days rest
        %li 51–65 pitches: 3 days rest
        %li 66+ pitches: 4 days rest

    %div{ class: "mt-4 text-sm" }
      %div{ class: "font-semibold" } Catcher rule (71+)
      %ul{ class: "mt-1 list-disc pl-5 space-y-1" }
        %li If a pitcher throws 71 or more pitches in a day, they cannot play catcher for the rest of that day (including later games).
        %li If a player has already played catcher in a day, they may not reach 71 or more pitches that day (exception: may finish the current batter).
