%div{ class: "max-w-4xl mx-auto px-6 py-8 text-stone-900" }

  %div{ class: "flex items-start justify-between gap-4 mb-6" }
    %div
      %h1{ class: "text-3xl font-semibold" }= @show.opp_name
      %p{ class: "text-sm text-stone-600 mt-1" }= @show.game_date
    %div{ class: "flex items-center gap-3" }
      = link_to "Edit Game", edit_game_path(@game), class: "border border-stone-900 px-4 py-2 text-sm hover:bg-stone-900 hover:text-white"
      - if @show.has_lineup?
        = link_to "Edit Lineup", game_lineup_path(@game), class: "border border-stone-900 px-4 py-2 text-sm hover:bg-stone-900 hover:text-white"
      - else
        = button_to "Create Lineup", game_lineup_path(@game), method: :post, class: "border border-stone-900 px-4 py-2 text-sm hover:bg-stone-900 hover:text-white"
      = link_to "Print Plan", print_plan_game_path(@game), target: "_blank", class: "border border-stone-900 px-4 py-2 text-sm hover:bg-stone-900 hover:text-white"

  %div{ class: "grid grid-cols-2 gap-6 mb-8" }
    %div
      %p{ class: "text-sm text-stone-600" } Opponent
      %p{ class: "text-lg font-medium" }= @show.opp_name
    %div
      %p{ class: "text-sm text-stone-600" } Location
      %p{ class: "text-lg font-medium" }= @game.location.presence || "TBD"

  = render partial: "scouting_report"

  = render partial: 'gameplan'

  = render partial: 'lineup'

  = render partial: 'pitch_counter'
