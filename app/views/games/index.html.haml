%div.max-w-4xl.mx-auto.px-6.py-8

  %div.flex.justify-between.items-center.mb-6
    %h1.text-2xl.font-semibold Games
    = link_to "New Game", new_game_path, class: "underline text-sm"

  %table.w-full.text-sm
    %thead
      %tr.border-b.border-stone-300
        %th.text-center.py-2 Date
        %th.text-center.py-2 Opponent
        %th.text-center.py-2 Home/Away
        %th.text-center.py-2

    %tbody
      - @games.each do |game|
        %tr.border-b.border-stone-200
          %td.py-3.text-center= link_to game.date.strftime('%m-%d-%y'), game_path(game), class: 'underline'
          %td.py-3.text-center= game.opponent_team&.name
          %td.py-3.text-center= home_away(game)
          %td.py-3.flex.gap-3
            = link_to 'Edit', edit_game_path(game), class: 'underline'
            = button_to 'Delete', game_path(game), method: :delete, class: 'underline text-red-500', data: { turbo_confirm: 'Are you sure?' }

