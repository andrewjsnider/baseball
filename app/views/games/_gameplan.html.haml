%div{ class: "border border-stone-200 bg-white p-5 mb-8" }
  %div{ class: "flex items-start justify-between gap-4 mb-4" }
    %div
      %h2{ class: "text-lg font-semibold" } Game Plan
      %p{ class: "text-sm text-stone-600 mt-1" } Pitching, limits, and alignment
    %div{ class: "flex items-center gap-3" }
      - if @show.has_lineup?
        = link_to "Edit Lineup", game_lineup_path(@game), class: "underline text-sm"

  %div{ class: "grid grid-cols-1 md:grid-cols-2 gap-6" }
    %div
      %p{ class: "text-sm text-stone-600" } Starting Pitcher
      %p{ class: "text-lg font-medium" }= @show.starting_pitcher_slot&.player&.name || "Not assigned"



  - if @show.has_lineup? && @show.missing_positions.any?
    %div{ class: "my-4 p-4 border border-red-300 bg-red-50 text-red-700 text-sm" }
      %strong Incomplete Defensive Alignment
      %p{ class: "mt-1" } Missing: #{@show.missing_positions.map(&:humanize).join(", ")}


    %div
      %p{ class: "text-sm text-stone-600" } Pitching Availability
      - eligible = @show.pitcher_rows.select(&:eligible_today)
      - resting = @show.pitcher_rows.reject(&:eligible_today)

      %p{ class: "text-lg font-medium" }= "#{eligible.size} eligible, #{resting.size} resting"

      - if resting.any?
        %div{ class: "text-sm text-stone-600 mt-2" }
          Next up:
          - resting.sort_by { |r| r.eligible_on }.first(3).each do |r|
            %div= "#{r.player.name}: #{r.eligible_on}"
%div{ class: "border border-stone-200 bg-white p-5 mb-8" }
  %div{ class: "flex items-start justify-between gap-4 mb-4" }
    %div
      %h2{ class: "text-lg font-semibold" } Pitching Plan
      %p{ class: "text-sm text-stone-600 mt-1" } Starter targets and relief order
    %div{ class: "flex items-center gap-3" }
      - if @show.has_lineup?
        = link_to "Edit Lineup", game_lineup_path(@game), class: "underline text-sm"

  :ruby
    role_labels = {
      "starter" => "Starter",
      "relief_1" => "Relief 1",
      "relief_2" => "Relief 2",
      "relief_3" => "Relief 3",
      "emergency" => "Emergency"
    }

    eligible_ids = @show.eligible_pitchers_for_game.map(&:id)

  %div{ class: "space-y-3" }
    - @show.pitch_plan_slots.each do |slot|
      :ruby
        label = role_labels.fetch(slot.role, slot.role.humanize)
        projected =
          if slot.player && slot.target_pitches.to_i > 0
            @show.projected_next_eligible_date(slot.player, slot.target_pitches)
          end

      %div{ class: "border border-stone-200 p-3" }
        %div{ class: "flex items-start justify-between gap-4" }
          %div
            %div{ class: "font-semibold" }= label
            %div{ class: "text-xs text-stone-600 mt-1" }
              - if slot.player
                - if eligible_ids.include?(slot.player.id)
                  Available today
                - else
                  Not eligible today
              - else
                Not assigned

            - if projected
              %div{ class: "text-xs text-stone-600 mt-1" }= "If used for #{slot.target_pitches}, eligible again on #{projected}"

          %div
            = form_with model: [@game, slot], method: :patch, local: true do |f|
              %div{ class: "flex items-center gap-2" }
                = f.select :player_id,
                  options_from_collection_for_select(@show.my_pitchers, :id, :name, slot.player_id),
                  { include_blank: true },
                  class: "border p-2 text-sm"

                = f.number_field :target_pitches, value: slot.target_pitches, placeholder: "Target", class: "border p-2 w-24 text-sm"

                = f.submit "Save", class: "border border-stone-900 px-3 py-2 text-sm hover:bg-stone-900 hover:text-white"