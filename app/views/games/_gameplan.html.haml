- summary = @show.pitching_availability_summary
- plan_rows = @show.pitch_plan_rows

%div{ class: "border border-stone-200 bg-white p-5 mb-8" }
  %div{ class: "flex items-start justify-between gap-4 mb-4" }
    %div
      %h2{ class: "text-lg font-semibold" } Game Plan
      %p{ class: "text-sm text-stone-600 mt-1" } Pitching, limits, and alignment
    %div{ class: "flex items-center gap-3" }
      - if @show.has_lineup?
        = link_to "Edit Lineup", game_lineup_path(@game), class: "underline text-sm"

  %div{ class: "grid grid-cols-1 md:grid-cols-2 gap-6" }
    %div
      %p{ class: "text-sm text-stone-600" } Starting Pitcher
      %p{ class: "text-lg font-medium" }= @show.starting_pitcher_name || "Not assigned"

    %div
      %p{ class: "text-sm text-stone-600" } Pitching Availability
      %p{ class: "text-lg font-medium" }= "#{summary.eligible_count} eligible, #{summary.resting_count} resting"
      - if summary.next_up_rows.any?
        %div{ class: "text-sm text-stone-600 mt-2" }
          Next up:
          - summary.next_up_rows.each do |r|
            %div= "#{r.player_name}: #{r.eligible_on}"

  - if @show.has_lineup? && @show.missing_positions.any?
    %div{ class: "my-4 p-4 border border-red-300 bg-red-50 text-red-700 text-sm" }
      %strong Incomplete Defensive Alignment
      %p{ class: "mt-1" } Missing: #{@show.missing_positions_label}

%div{ class: "border border-stone-200 bg-white p-5 mb-8" }
  %div{ class: "flex items-start justify-between gap-4 mb-4" }
    %div
      %h2{ class: "text-lg font-semibold" } Pitching Plan
      %p{ class: "text-sm text-stone-600 mt-1" } Starter targets and relief order
    %div{ class: "flex items-center gap-3" }
      - if @show.has_lineup?
        = link_to "Edit Lineup", game_lineup_path(@game), class: "underline text-sm"

  %div{ class: "space-y-3" }
    - plan_rows.each do |row|
      %div{ class: "border border-stone-200 p-3" }
        %div{ class: "flex items-start justify-between gap-4" }
          %div
            %div{ class: "font-semibold" }= row.label
            %div{ class: "text-xs text-stone-600 mt-1" }= row.availability_label

            - if row.projected_eligible_on
              %div{ class: "text-xs text-stone-600 mt-1" }= "If used for #{row.target_pitches}, eligible again on #{row.projected_eligible_on}"

          %div
            = form_with model: [@game, row.slot], method: :patch, local: true do |f|
              %div{ class: "flex items-center gap-2" }
                - if row.locked_from_lineup
                  %div{ class: "border p-2 text-sm w-48 bg-stone-50" }= row.player_name || "Not assigned"
                  = f.hidden_field :player_id, value: row.player_id
                - else
                  = f.select :player_id,
                    options_from_collection_for_select(@show.my_pitchers, :id, :name, row.slot.player_id),
                    { include_blank: true },
                    class: "border p-2 text-sm"

                = f.number_field :target_pitches, value: row.target_pitches, placeholder: "Target", class: "border p-2 w-24 text-sm"
                = f.submit "Save", class: "border border-stone-900 px-3 py-2 text-sm hover:bg-stone-900 hover:text-white"