:ruby
  opp_name = @game.opponent_team&.name || @game.opponent

  opponent_linked = @opponent_team.present?
  opponent_has_players = @opponent_players.present? && @opponent_players.any?

  pitcher_vals = opponent_has_players ? @opponent_players.map { |p| p.agg_pitch.to_f }.reject(&:zero?) : []
  offense_vals = opponent_has_players ? @opponent_players.map { |p| p.agg_bat.to_f }.reject(&:zero?) : []
  defense_vals =
    if opponent_has_players
      @opponent_players.map do |p|
        inf = p.agg_infield.to_f
        outf = p.agg_outfield.to_f
        next nil if inf.zero? && outf.zero?
        if inf.positive? && outf.positive?
          (inf + outf) / 2.0
        else
          inf.positive? ? inf : outf
        end
      end.compact
    else
      []
    end

  pitcher_score = pitcher_vals.any? ? (pitcher_vals.sum / pitcher_vals.size) : nil
  offensive_score = offense_vals.any? ? (offense_vals.sum / offense_vals.size) : nil
  defensive_score = defense_vals.any? ? (defense_vals.sum / defense_vals.size) : nil

  player_def_score = lambda do |p|
    inf = p.agg_infield.to_f
    outf = p.agg_outfield.to_f
    return nil if inf.zero? && outf.zero?
    if inf.positive? && outf.positive?
      (inf + outf) / 2.0
    else
      inf.positive? ? inf : outf
    end
  end

  offense_sorted = opponent_has_players ? @opponent_players.sort_by { |p| -(p.agg_bat.to_f) }.first(5) : []
  pitching_sorted =
    if opponent_has_players
      @opponent_players.select(&:can_pitch).sort_by { |p| -(p.agg_pitch.to_f) }.first(5)
    else
      []
    end

  defense_sorted = opponent_has_players ? @opponent_players.sort_by { |p| -(player_def_score.call(p).to_f) }.first(5) : []


%div{ class: "border border-stone-200 p-5 bg-stone-50 mb-8" }
  %div{ class: "flex items-start justify-between gap-4" }
    %div
      %h2{ class: "text-lg font-semibold" } Scouting Report
      %p{ class: "text-sm text-stone-600 mt-1" }= opp_name
    %div{ class: "flex items-center gap-3" }
      - if @game.opponent_team
        = link_to "Opponent Roster", team_path(@game.opponent_team), class: "underline text-sm"
      = link_to "Edit Game", edit_game_path(@game), class: "underline text-sm"

  - if !opponent_linked
    %p{ class: "text-sm text-stone-600 mt-4" }
      No opponent team linked yet. Link a Team to this game to enable scouting.
  - elsif !opponent_has_players
    %p{ class: "text-sm text-stone-600 mt-4" }
      Opponent team has no players yet.
  - else
    %div{ class: "grid grid-cols-2 md:grid-cols-4 gap-4 mt-5" }
      %div
        %p{ class: "text-xs uppercase tracking-wide text-stone-500" } Players
        %p{ class: "text-lg font-semibold" }= @opponent_players.size
      %div
        %p{ class: "text-xs uppercase tracking-wide text-stone-500" } Pitcher Score
        %p{ class: "text-lg font-semibold" }= pitcher_score ? pitcher_score.round(1) : "n/a"
      %div
        %p{ class: "text-xs uppercase tracking-wide text-stone-500" } Offensive Score
        %p{ class: "text-lg font-semibold" }= offensive_score ? offensive_score.round(1) : "n/a"
      %div
        %p{ class: "text-xs uppercase tracking-wide text-stone-500" } Defensive Score
        %p{ class: "text-lg font-semibold" }= defensive_score ? defensive_score.round(1) : "n/a"

    %div{ class: "grid grid-cols-1 md:grid-cols-3 gap-4 mt-6" }
      %div{ class: "border border-stone-200 bg-white p-4" }
        %h3{ class: "text-sm font-semibold mb-2" } Top Offense
        %ol{ class: "list-decimal ml-5 text-sm space-y-1" }
          - offense_sorted.each do |p|
            - s = p.agg_bat.to_f

            %li
              = p.name
              %span{ class: "text-stone-500 ml-2" } (Off #{s.positive? ? s.round(1) : "?"})

      %div{ class: "border border-stone-200 bg-white p-4" }
        %h3{ class: "text-sm font-semibold mb-2" } Top Pitching
        %ol{ class: "list-decimal ml-5 text-sm space-y-1" }
          - pitching_sorted.each do |p|
            :ruby
              s = p.agg_pitch.to_f
            %li
              = p.name
              %span{ class: "text-stone-500 ml-2" } (Pit #{s.positive? ? s.round(1) : "?"})

      %div{ class: "border border-stone-200 bg-white p-4" }
        %h3{ class: "text-sm font-semibold mb-2" } Top Defense
        %ol{ class: "list-decimal ml-5 text-sm space-y-1" }
          - defense_sorted.each do |p|
            :ruby
              s = player_def_score.call(p)
            %li
              = p.name
              %span{ class: "text-stone-500 ml-2" } (Def #{s ? s.round(1) : "?"})