- report = @show.scouting_report

%div{ class: "border border-stone-200 p-5 bg-stone-50 mb-8" }
  %div{ class: "flex items-start justify-between gap-4" }
    %div
      %h2{ class: "text-lg font-semibold" } Scouting Report
      %p{ class: "text-sm text-stone-600 mt-1" }= report.opp_name
    %div{ class: "flex items-center gap-3" }
      - if report.opponent_roster_link?
        = link_to "Opponent Roster", team_path(@game.opponent_team), class: "underline text-sm"
      = link_to "Edit Game", edit_game_path(@game), class: "underline text-sm"

  - if !report.opponent_linked?
    %p{ class: "text-sm text-stone-600 mt-4" }
      No opponent team linked yet. Link a Team to this game to enable scouting.
  - elsif !report.opponent_has_players?
    %p{ class: "text-sm text-stone-600 mt-4" }
      Opponent team has no players yet.
  - else
    %div{ class: "grid grid-cols-2 md:grid-cols-4 gap-4 mt-5" }
      %div
        %p{ class: "text-xs uppercase tracking-wide text-stone-500" } Players
        %p{ class: "text-lg font-semibold" }= report.players_count
      %div
        %p{ class: "text-xs uppercase tracking-wide text-stone-500" } Pitcher Score
        %p{ class: "text-lg font-semibold" }= report.pitcher_score ? report.pitcher_score.round(1) : "n/a"
      %div
        %p{ class: "text-xs uppercase tracking-wide text-stone-500" } Offensive Score
        %p{ class: "text-lg font-semibold" }= report.offensive_score ? report.offensive_score.round(1) : "n/a"
      %div
        %p{ class: "text-xs uppercase tracking-wide text-stone-500" } Defensive Score
        %p{ class: "text-lg font-semibold" }= report.defensive_score ? report.defensive_score.round(1) : "n/a"

    %div{ class: "grid grid-cols-1 md:grid-cols-3 gap-4 mt-6" }
      %div{ class: "border border-stone-200 bg-white p-4" }
        %h3{ class: "text-sm font-semibold mb-2" } Top Offense
        %ol{ class: "list-decimal ml-5 text-sm space-y-1" }
          - report.top_offense.each do |row|
            %li
              = row[:player].name
              %span{ class: "text-stone-500 ml-2" } (Off #{row[:score].positive? ? row[:score].round(1) : "?"})

      %div{ class: "border border-stone-200 bg-white p-4" }
        %h3{ class: "text-sm font-semibold mb-2" } Top Pitching
        %ol{ class: "list-decimal ml-5 text-sm space-y-1" }
          - report.top_pitching.each do |row|
            %li
              = row[:player].name
              %span{ class: "text-stone-500 ml-2" } (Pit #{row[:score].positive? ? row[:score].round(1) : "?"})

      %div{ class: "border border-stone-200 bg-white p-4" }
        %h3{ class: "text-sm font-semibold mb-2" } Top Defense
        %ol{ class: "list-decimal ml-5 text-sm space-y-1" }
          - report.top_defense.each do |row|
            %li
              = row[:player].name
              %span{ class: "text-stone-500 ml-2" } (Def #{row[:score].positive? ? row[:score].round(1) : "?"})