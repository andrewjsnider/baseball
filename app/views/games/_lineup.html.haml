%div{ class: "border border-stone-200 bg-white p-5" }
  %div{ class: "flex items-center justify-between gap-4 mb-4" }
    %h2{ class: "text-lg font-semibold" } Batting Order
    %div{ class: "flex items-center gap-3" }
      - if @show.has_lineup?
        = link_to "Edit Lineup", game_lineup_path(@game), class: "underline text-sm"

  - if !@show.has_lineup?
    %p{ class: "text-sm text-stone-600" } No lineup created yet.
  - else
    %div{ class: "border border-stone-200" }
      %div{ class: "grid grid-cols-12 gap-2 px-2 py-1 border-b border-stone-200 bg-stone-50 font-semibold text-sm" }
        %div{ class: "col-span-1" } #
        %div{ class: "col-span-6" } Batter
        %div{ class: "col-span-2 text-center whitespace-nowrap" } 1-2
        %div{ class: "col-span-2 text-center whitespace-nowrap" } 3-4

      - @game.lineup.lineup_slots.order(:batting_order).each_with_index do |slot, idx|
        %div{ class: "grid grid-cols-12 gap-2 px-2 py-2 border-b border-stone-200 text-sm" }
          %div{ class: "col-span-1 text-stone-600" }= idx + 1
          %div{ class: "col-span-6 font-semibold" }= slot.player.name
          %div{ class: "col-span-2 text-center text-stone-700 whitespace-nowrap" }= slot.first_two_abbreviation || "-"
          %div{ class: "col-span-2 text-center text-stone-700 whitespace-nowrap" }= slot.second_two_abbreviation || "-"

    - if @show.missing_positions.any?
      %div{ class: "mt-2 text-red-700 font-semibold text-sm" }= "Missing: #{@show.missing_positions_label}"
